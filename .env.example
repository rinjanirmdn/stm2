APP_NAME="e-Docking Control System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Admin notification email
ADMIN_EMAIL=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: use 'pgsql' for PostgreSQL or 'mysql' for MySQL/MariaDB
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=warehouse
DB_SCHEMA=slot_time_management
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ===== SAP API Configuration =====
# Base URL untuk SAP Gateway
SAP_PO_BASE_URL=https://192.104.210.16:44320

# Service path untuk OData V4 PO service
SAP_PO_SERVICE_PATH=/sap/opu/odata4/sap/zmm_oji_po_bind/srvd/sap/zmm_oji_po/0001

# OData detail endpoint template (use {po} as placeholder for PO number)
# Contoh lengkap: /sap/opu/odata4/sap/zmm_oji_po_bind/srvd/sap/zmm_oji_po/0001/ZPO_HDR_VNAME(po_no='4110002539')/Set
SAP_PO_ODATA_DETAIL_ENDPOINT=/ZPO_HDR_VNAME(po_no='{po}')/Set

# SAP Client header
SAP_PO_SAP_CLIENT=210

# Authentication (opsional - saat ini SAP gateway mengizinkan akses tanpa auth)
# Pilih salah satu: Bearer Token ATAU Basic Auth
SAP_PO_TOKEN=
SAP_PO_USERNAME=
SAP_PO_PASSWORD=

# SSL verification (set false jika menggunakan self-signed certificate)
SAP_PO_VERIFY_SSL=false

# Request timeout dalam detik
SAP_PO_TIMEOUT=15

# ===== SAP Vendor API Configuration (jika ada service vendor terpisah) =====
SAP_VENDOR_BASE_URL=
SAP_VENDOR_SERVICE_PATH=
SAP_VENDOR_SAP_CLIENT=210

# ===== Reverb/Broadcasting (opsional - tidak aktif saat ini) =====
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
